{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    "noEmit": false,
    "types": ["jest", "node"],
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src", "tests"]
}
